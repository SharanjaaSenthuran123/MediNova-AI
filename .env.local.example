# Copy this file to .env.local (never commit .env.local)
# Full Atlas setup: docs/MONGODB-ATLAS.md

# --- Express API (MongoDB required — no demo mode) ---
API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/medinova
#
# MongoDB Atlas — option A: full connection string (URL-encode special chars in password):
# MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/medinova
#
# MongoDB Atlas — option B: split vars (handles @, #, : in passwords automatically):
# MONGODB_ATLAS_USER=YOUR_USER
# MONGODB_ATLAS_PASSWORD=YOUR_PASSWORD
# MONGODB_ATLAS_CLUSTER=YOUR_CLUSTER.mongodb.net
# MONGODB_DB=medinova
MONGODB_URI=mongodb://127.0.0.1:27017/medinova

# Auth (this project uses JWT — not NextAuth)
JWT_SECRET=change-this-in-production

# --- Live AI (OpenAI primary, Gemini fallback) ---
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- Email (Nodemailer SMTP) ---
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MediNova AI <noreply@medinova.ai>"

# --- SMS (Twilio) — caretaker SOS texts ---
# Get keys at https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15551234567
# Twilio trial: route all SOS SMS to your verified number
EMERGENCY_SMS_TO=+15559876543

# --- Frontend ---
CLIENT_URL=http://localhost:3000

# Production (Vercel): set API_URL to your Render/Railway API host
# API_URL=https://medinova-api.onrender.com
# NEXT_PUBLIC_SOCKET_URL=https://medinova-api.onrender.com

# Default map center when GPS unavailable (Colombo, Sri Lanka)
# NEXT_PUBLIC_DEFAULT_LAT=6.9271
# NEXT_PUBLIC_DEFAULT_LNG=79.8612
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Payments ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
