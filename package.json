{
  "name": "medinova-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:server": "npm run dev --prefix server",
    "dev:web": "node scripts/start-next-dev.mjs",
    "dev:frontend": "node scripts/ensure-dev-ready.mjs && npx next dev -p 3000",
    "dev": "node scripts/prepare-dev.mjs && concurrently -k -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:clean": "node scripts/clean-dev-cache.mjs && concurrently -k -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:reset": "node scripts/dev-reset.mjs",
    "seed": "npm run seed --prefix server",
    "env:init": "node scripts/init-env.mjs",
    "env:set": "node scripts/set-openai-key.mjs",
    "mongo:set": "node scripts/set-mongodb-uri.mjs",
    "mongo:test": "node scripts/test-mongo.mjs",
    "env:check": "node -e \"fetch('http://localhost:3000/api/config/status').then(r=>r.json()).then(j=>console.log(JSON.stringify(j,null,2))).catch(e=>console.error('Start npm run dev first'))\"",
    "build": "node scripts/kill-dev-ports.mjs && npx next build",
    "postbuild": "node scripts/mark-production-build.mjs",
    "start": "concurrently -k \"npm run start --prefix server\" \"node scripts/ensure-prod-ready.mjs && npx next start\"",
    "lint": "npx next lint",
    "postinstall": "npm install --prefix server"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "mongoose": "^9.6.2",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "openai": "^6.38.0",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
